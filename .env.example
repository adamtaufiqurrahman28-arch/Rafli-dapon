# Django
SECRET_KEY=change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database
# DEFAULT KOSONG = pakai SQLite lokal, paling gampang untuk jalanin app.
DATABASE_URL=

# OPTIONAL nanti kalau mau balik ke Supabase, isi DATABASE_URL dengan connection string Supabase.
# Contoh DIRECT Supabase:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Contoh SESSION POOLER Supabase:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# App branding
APP_NAME=Lunch Order RNZ
POWERED_BY=Rafli
DEFAULT_PICKUP_WINDOW=11.00 - 12.00 WIB
DEFAULT_ORDER_WINDOW=09.00 - 10.50 WIB
